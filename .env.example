# =============================================================================
# Model provider selection
# =============================================================================
# Supported values:
#   anthropic
#   openai_azure
MODEL_PROVIDER=anthropic

# =============================================================================
# Anthropic mode
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx
MODEL_ID=claude-sonnet-4-6

# Optional, for Anthropic-compatible providers
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- Anthropic-compatible providers examples ----

# MiniMax          https://api.minimax.io/anthropic
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://api.z.ai/api/anthropic
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://api.moonshot.ai/anthropic
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek         https://api.deepseek.com/anthropic
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# =============================================================================
# Azure OpenAI / ModelHub mode
# =============================================================================
# MODEL_PROVIDER=openai_azure
# MODEL_ID=gpt-5.4-2026-03-05
# AZURE_OPENAI_API_KEY=your_api_key
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_ENDPOINT=https://aidp.bytedance.net/api/modelhub/online/v2/crawl
# AZURE_OPENAI_LOGID=your_logid
